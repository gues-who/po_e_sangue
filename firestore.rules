// Cole estas regras em:
// Firebase Console → Firestore Database → Regras
//
// ATENÇÃO: substitua "mestre@seudominio.com" pelo mesmo e-mail
// definido em ADMIN_EMAIL dentro de firebase-config.js
//
// Depois clique em "Publicar".

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /fichas/{userId} {
      // Cada jogador lê e grava apenas a própria ficha
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // O mestre (admin) pode ler todas as fichas
      allow read: if request.auth != null
                  && request.auth.token.email == "mestre@seudominio.com";
    }
  }
}
